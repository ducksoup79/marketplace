# Copy to .env and fill in values. Do not commit .env.

# Server
PORT=3001
NODE_ENV=production

# Database (PostgreSQL)
# On macOS (Postgres.app / Homebrew) the default user is often your Mac username, not "postgres".
DB_HOST=localhost
DB_PORT=5432
DB_USER=johannesgroenewald
DB_PASSWORD=
DB_NAME=marketplace

# Admin account (created by npm run setup)
ADMIN_PASSWORD=admin123

# JWT (use long random strings in production)
JWT_SECRET=your_jwt_secret_min_32_chars
REFRESH_TOKEN_SECRET=your_refresh_secret_or_same_as_jwt

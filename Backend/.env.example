# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_password
DB_NAME=marketplace

# Admin account (used by npm run setup)
ADMIN_EMAIL=admin@marketplace.com
ADMIN_PASSWORD=changeme

# JWT secrets (use long random strings in production)
JWT_SECRET=your_jwt_secret_min_32_chars_long
REFRESH_TOKEN_SECRET=your_refresh_secret_min_32_chars

# Server
PORT=3001

# Optional: for email (verify, reset password)
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# FROM_EMAIL=noreply@marketplace.com
